# .env 파일로 복사 후 실제 키 입력
# cp .env.example .env

# -- 필수 ----------------------------
ANTHROPIC_API_KEY=sk-ant-여기에입력

# -- 이미지 생성 (하나만 선택) -------
# 옵션 A: HuggingFace 무료 (추천 시작점)
HUGGINGFACE_API_KEY=hf_여기에입력
IMAGE_BACKEND=huggingface

# 옵션 B: 로컬 Stable Diffusion (GPU 있을 때)
# IMAGE_BACKEND=local_sd

# 옵션 C: Replicate 유료 ($0.003/컷)
# REPLICATE_API_TOKEN=r8_여기에입력
# IMAGE_BACKEND=replicate

# -- 영상 모드 -----------------------
# slideshow: 이미지+자막+TTS (무료, 추천)
# ai_video: Wan2.1 영상 생성 (로컬 GPU 필요)
VIDEO_MODE=slideshow
